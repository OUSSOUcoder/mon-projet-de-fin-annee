/**
 * useX3DH — Hook React
 * Gère le cycle de vie complet X3DH :
 *   - Inscription (génération + publication bundle)
 *   - Connexion (chargement identité depuis IndexedDB)
 *   - Initiation de session (Alice → Bob hors-ligne)
 *   - Réception de session (Bob reçoit message initial)
 *   - Rotation SPK + replenishment OTPKs
 */

import { useState, useEffect, useRef, useCallback } from 'react';
import { X3DHIdentity, x3dhSenderInitiate, x3dhReceiverProcess } from '../crypto/X3DH';
import { IdentityStorage } from '../crypto/IdentityStorage';
import { DHRatchet } from '../crypto/DHRatchet';

export function useX3DH(socket, username) {
  const [identity, setIdentity]         = useState(null);
  const [isReady, setIsReady]           = useState(false);
  const [isLoading, setIsLoading]       = useState(false);
  const [error, setError]               = useState(null);
  const [otpkCount, setOtpkCount]       = useState(0);

  const storageRef  = useRef(new IdentityStorage());
  const ratchetsRef = useRef(new Map());     // contactId → DHRatchet
  const identityRef = useRef(null);
  const passwordRef = useRef(null);          // mot de passe en mémoire (session uniquement)

  // ─── Mise à jour de la ref quand identity change ──
  useEffect(() => {
    identityRef.current = identity;
    if (identity) {
      setOtpkCount(identity.getRemainingOneTimePreKeyCount());
    }
  }, [identity]);

  // ─── Écouter les demandes de replenishment OTPKs ─
  useEffect(() => {
    if (!socket) return;

    socket.on('prekeys-low', async ({ remaining }) => {
      console.log(`⚠️ OTPKs bas: ${remaining} restantes`);
      if (identityRef.current && passwordRef.current) {
        await identityRef.current.replenishOneTimePreKeys(50);
        await storageRef.current.updateIdentity(
          username, identityRef.current, passwordRef.current
        );
        const bundle = await identityRef.current.buildPreKeyBundle();
        socket.emit('publish-new-prekeys', {
          oneTimePreKeys: bundle.oneTimePreKeys
        });
        setOtpkCount(identityRef.current.getRemainingOneTimePreKeyCount());
        console.log('✅ 50 nouvelles OTPKs publiées');
      }
    });

    // Rotation SPK hebdomadaire
    socket.on('spk-rotation-needed', async () => {
      if (identityRef.current && passwordRef.current) {
        const rotated = await identityRef.current.rotateSignedPreKeyIfNeeded();
        if (rotated) {
          await storageRef.current.updateIdentity(
            username, identityRef.current, passwordRef.current
          );
          const bundle = await identityRef.current.buildPreKeyBundle();
          socket.emit('publish-prekey-bundle', { bundle });
        }
      }
    });

    return () => {
      socket.off('prekeys-low');
      socket.off('spk-rotation-needed');
    };
  }, [socket, username]);

  // ─────────────────────────────────────────────
  // INSCRIPTION : première utilisation
  // ─────────────────────────────────────────────

  /**
   * Génère une nouvelle identité X3DH et la publie sur le serveur.
   * À appeler une seule fois lors de l'inscription.
   *
   * @param {string} password - mot de passe pour chiffrer les clés privées
   */
  const register = useCallback(async (password) => {
    setIsLoading(true);
    setError(null);

    try {
      await storageRef.current.init();

      // Vérifier si une identité existe déjà
      const exists = await storageRef.current.hasIdentity(username);
      if (exists) {
        throw new Error('Une identité existe déjà. Utilisez login() pour vous connecter.');
      }

      // Générer l'identité complète
      const newIdentity = await new X3DHIdentity().generate();

      // Sauvegarder chiffrée localement
      await storageRef.current.saveIdentity(username, newIdentity, password);
      passwordRef.current = password;

      // Construire et publier le bundle
      const bundle = await newIdentity.buildPreKeyBundle();
      socket.emit('publish-prekey-bundle', { username, bundle });

      setIdentity(newIdentity);
      setIsReady(true);
      setOtpkCount(newIdentity.getRemainingOneTimePreKeyCount());

      console.log('✅ Inscription X3DH complète');
      return { success: true, bundle };

    } catch (err) {
      setError(err.message);
      console.error('❌ Erreur inscription X3DH:', err);
      return { success: false, error: err.message };
    } finally {
      setIsLoading(false);
    }
  }, [socket, username]);

  // ─────────────────────────────────────────────
  // CONNEXION : utilisateur existant
  // ─────────────────────────────────────────────

  /**
   * Charge l'identité depuis IndexedDB en déchiffrant avec le mot de passe.
   *
   * @param {string} password
   */
  const login = useCallback(async (password) => {
    setIsLoading(true);
    setError(null);

    try {
      await storageRef.current.init();

      const loadedIdentity = await storageRef.current.loadIdentity(username, password);
      passwordRef.current  = password;

      // Vérifier si SPK doit être renouvelée
      await loadedIdentity.rotateSignedPreKeyIfNeeded();

      // Republier le bundle (pour indiquer qu'on est en ligne)
      const bundle = await loadedIdentity.buildPreKeyBundle();
      socket.emit('publish-prekey-bundle', { username, bundle });

      setIdentity(loadedIdentity);
      setIsReady(true);
      setOtpkCount(loadedIdentity.getRemainingOneTimePreKeyCount());

      console.log('✅ Connexion X3DH réussie');
      return { success: true };

    } catch (err) {
      setError(err.message);
      console.error('❌ Erreur connexion X3DH:', err);
      return { success: false, error: err.message };
    } finally {
      setIsLoading(false);
    }
  }, [socket, username]);

  // ─────────────────────────────────────────────
  // INITIER UNE SESSION (expéditeur)
  // ─────────────────────────────────────────────

  /**
   * Alice initie une session avec Bob.
   * Télécharge le bundle de Bob depuis le serveur et calcule le secret partagé.
   *
   * @param {string} recipientUsername
   * @returns {DHRatchet} — ratchet prêt à chiffrer
   */
  const initiateSession = useCallback(async (recipientUsername) => {
    const currentIdentity = identityRef.current;
    if (!currentIdentity) throw new Error('Identité non chargée');

    // Déjà une session active ?
    if (ratchetsRef.current.has(recipientUsername)) {
      return ratchetsRef.current.get(recipientUsername);
    }

    // Télécharger le bundle du destinataire
    const bundle = await new Promise((resolve, reject) => {
      socket.emit('get-prekey-bundle', { username: recipientUsername });
      socket.once(`prekey-bundle:${recipientUsername}`, resolve);
      setTimeout(() => reject(new Error(`Timeout: bundle de ${recipientUsername} non reçu`)), 10000);
    });

    if (!bundle) {
      throw new Error(`Aucun bundle PreKey pour ${recipientUsername}`);
    }

    // Calculer le secret X3DH
    const { sessionKey, initialMessage, usedOTPKId } =
      await x3dhSenderInitiate(currentIdentity, bundle);

    // Initialiser le Double Ratchet avec le sessionKey
    const isInitiator = username.localeCompare(recipientUsername) < 0;
    const ratchet     = new DHRatchet(sessionKey, isInitiator);
    const spkPublic   = await importPublicKeyFromJWK(bundle.signedPreKey.publicKey);

    if (isInitiator) {
      const { generateECDHKeyPair } = await import('./Primitives');
      const dhKeyPair = await generateECDHKeyPair();
      await ratchet.initialize(dhKeyPair, spkPublic);
    } else {
      await ratchet.initialize(currentIdentity.identityKeyPair, null);
    }

    ratchetsRef.current.set(recipientUsername, ratchet);

    console.log(`✅ Session X3DH initiée avec ${recipientUsername} (OTPK: ${usedOTPKId ? 'oui' : 'non'})`);

    return { ratchet, initialMessage, usedOTPKId };

  }, [socket, username]);

  // ─────────────────────────────────────────────
  // RECEVOIR UNE SESSION (destinataire)
  // ─────────────────────────────────────────────

  /**
   * Bob reçoit un message initial d'Alice et reconstruit la session.
   *
   * @param {object} initialMessage - header X3DH inclus dans le premier message
   * @param {string} senderUsername
   * @returns {DHRatchet}
   */
  const receiveSession = useCallback(async (initialMessage, senderUsername) => {
    const currentIdentity = identityRef.current;
    if (!currentIdentity) throw new Error('Identité non chargée');

    // Session déjà établie ?
    if (ratchetsRef.current.has(senderUsername)) {
      return ratchetsRef.current.get(senderUsername);
    }

    // Recalculer le secret X3DH
    const { sessionKey, senderIdentityKey } =
      await x3dhReceiverProcess(currentIdentity, initialMessage);

    // Sauvegarder l'identité mise à jour (OTPK consommée)
    if (passwordRef.current) {
      await storageRef.current.updateIdentity(username, currentIdentity, passwordRef.current);
    }

    // Initialiser le Double Ratchet
    const isInitiator = username.localeCompare(senderUsername) < 0;
    const ratchet     = new DHRatchet(sessionKey, isInitiator);

    if (isInitiator) {
      const { generateECDHKeyPair } = await import('./Primitives');
      const dhKeyPair = await generateECDHKeyPair();
      await ratchet.initialize(dhKeyPair, senderIdentityKey);
    } else {
      await ratchet.initialize(currentIdentity.identityKeyPair, null);
    }

    ratchetsRef.current.set(senderUsername, ratchet);

    setOtpkCount(currentIdentity.getRemainingOneTimePreKeyCount());
    console.log(`✅ Session X3DH reçue de ${senderUsername}`);

    return ratchet;

  }, [username]);

  // ─────────────────────────────────────────────
  // ACCESSEURS
  // ─────────────────────────────────────────────

  const getRatchet = useCallback((contactUsername) => {
    return ratchetsRef.current.get(contactUsername) || null;
  }, []);

  const hasSession = useCallback((contactUsername) => {
    return ratchetsRef.current.has(contactUsername);
  }, []);

  const getIdentityPublicKey = useCallback(async () => {
    if (!identityRef.current) return null;
    const { exportPublicKey } = await import('./Primitives');
    return exportPublicKey(identityRef.current.identityKeyPair.publicKey);
  }, []);

  return {
    // État
    identity,
    isReady,
    isLoading,
    error,
    otpkCount,

    // Actions
    register,
    login,
    initiateSession,
    receiveSession,

    // Accesseurs
    getRatchet,
    hasSession,
    getIdentityPublicKey,

    // Refs directes
    identityRef,
    ratchetsRef
  };
}

// Helper
async function importPublicKeyFromJWK(jwk) {
  return crypto.subtle.importKey(
    'jwk',
    jwk,
    { name: 'ECDH', namedCurve: 'P-256' },
    true,
    []
  );
}